# --- LLM (OpenAI-compatible) --- REQUIRED
# Any OpenAI-compatible provider works: OpenAI, OpenRouter, an Iranian gateway, etc.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MODEL_SUMMARY=gpt-4o-mini
LLM_MODEL_CONTEXT_SUMMARY=gpt-4o-mini

# --- Legacy course variables (all optional now) ---
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional: for evaluation and LLMOps (Opik). Restart Docker infra after setting.
COMET_API_KEY=
