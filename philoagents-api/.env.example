# --- LLM (OpenAI-compatible) --- REQUIRED
# Any OpenAI-compatible provider works: OpenAI, OpenRouter, an Iranian gateway, etc.
# NOTE: docker --env-file does NOT support inline comments; keep values clean.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MODEL_SUMMARY=gpt-4o-mini
LLM_MODEL_CONTEXT_SUMMARY=gpt-4o-mini

# --- Embeddings (OpenAI-compatible) --- REQUIRED for RAG (Phase 2)
# Local dev: LM Studio serving BGE-M3. host.docker.internal reaches your
# Windows host from inside the container. Match the port to LM Studio.
# Online later: point BASE_URL/KEY at DeepInfra, Cloudflare, AvalAI, etc.
# EMBEDDING_DIM must match the model output size (BGE-M3 = 1024).
EMBEDDING_API_KEY=lm-studio
EMBEDDING_BASE_URL=http://host.docker.internal:9966/v1
EMBEDDING_MODEL=text-embedding-bge-m3
EMBEDDING_DIM=1024

# --- Legacy course variables (all optional now) ---
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional: for evaluation and LLMOps (Opik). Restart Docker infra after setting.
COMET_API_KEY=
